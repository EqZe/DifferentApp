{
  "expo": {
    "name": "Different",
    "slug": "different",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/different logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/different logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ilayrachkovski.different",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/different logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.differentapp.com",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "./plugins/onesignal-config.js",
      "./plugins/fix-material-theme.js",
      "./plugins/gradle-config.js"
    ],
    "scheme": "different",
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {},
      "backendUrl": "https://8fazvn3hy8nmzjsg6kz2u68p6xpbp6gk.app.specular.dev",
      "oneSignalAppId": "b732b467-6886-4c7b-b3d9-5010de1199d6",
      "eas": {
        "projectId": "fe404aca-e46f-42c2-ac3a-50c265d87ae7"
      }
    }
  }
}